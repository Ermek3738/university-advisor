# Copy this file to .env and fill in your values.

# Anthropic API key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Database URL. Leave empty for local SQLite (backend/universities.db).
# For Supabase/Postgres use the direct connection string, not the pooler.
DATABASE_URL=

# Claude model. Defaults to claude-sonnet-4-20250514 if unset.
CLAUDE_MODEL=claude-sonnet-4-20250514
